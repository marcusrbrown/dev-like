---
export interface Props {
  command: string;
  event: string;
}

const { command, event } = Astro.props;
---

<div class="command-block-wrapper">
  <div class="command-block">{command}</div>
  <button
    type="button"
    class="copy-button"
    data-copy-button
    data-command={command}
    data-umami-event={event}
    aria-label={`Copy command: ${command}`}
    title="Copy"
  >
    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="icon-copy"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="icon-copied" style="display:none;"><polyline points="20 6 9 17 4 12"></polyline></svg>
    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="icon-failed" style="display:none;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </button>
</div>

{/*
  Copy-to-clipboard behavior is bound globally via the site-wide Head override
  (src/components/Head.astro), which delegates a single document-level click
  handler to any [data-copy-button] element on the page. This lets pages that
  render raw button HTML without this component (e.g. generated registry
  pages, the landing page's hero CTA) get working copy behavior too, without
  needing this component's script to be bundled on their page.
*/}
